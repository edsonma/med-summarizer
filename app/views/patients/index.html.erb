<h1>Patients</h1>
<p class="muted">Upload lab reports, imaging reports and prescriptions, then ask for a grounded, cited summary.</p>

<div class="grid2">
  <div class="card">
    <h2 style="margin-top:0">Patient roster</h2>
    <% if @patients.any? %>
      <table>
        <thead><tr><th>Name</th><th>MRN</th><th>Docs</th><th></th></tr></thead>
        <tbody>
          <% @patients.each do |patient| %>
            <tr>
              <td><%= patient.name %></td>
              <td class="small muted"><%= patient.mrn %></td>
              <td><%= patient.documents.size %></td>
              <td class="right"><%= link_to "Open", patient_path(patient), class: "cite" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="muted">No patients yet. Create one, or run <code>bin/rails db:seed</code>.</p>
    <% end %>
  </div>

  <div class="card">
    <h2 style="margin-top:0">New patient</h2>
    <%= form_with model: @patient, url: patients_path, method: :post do |f| %>
      <%= f.label :name %>
      <%= f.text_field :name, placeholder: "Jane Doe" %>
      <%= f.label :mrn, "MRN" %>
      <%= f.text_field :mrn, placeholder: "MRN-0001" %>
      <%= f.submit "Create patient", class: "btn" %>
    <% end %>
  </div>
</div>

<h2>Recent summaries</h2>
<div class="card">
  <% if @recent_summaries.any? %>
    <table>
      <thead><tr><th>When</th><th>Query</th><th>Status</th><th>Conf.</th><th></th></tr></thead>
      <tbody>
        <% @recent_summaries.each do |summary| %>
          <tr>
            <td class="small muted"><%= summary.created_at.strftime("%b %d %H:%M") %></td>
            <td><%= truncate(summary.query, length: 60) %></td>
            <td><span class="badge badge-<%= summary.status %>"><%= summary.status %></span></td>
            <td class="small"><%= summary.confidence ? "#{(summary.confidence * 100).round}%" : "-" %></td>
            <td class="right"><%= link_to "View", summary_path(summary), class: "cite" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="muted">No summaries yet.</p>
  <% end %>
</div>
