# Copy to .env and fill in. .env is git-ignored.

# Required for live LLM + embedding calls (OpenAI).
OPENAI_API_KEY=sk-your-key-here

# Optional overrides (defaults shown).
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Retrieval tuning (Parent Document Retrieval).
CHILD_CHUNK_TOKENS=120
PARENT_CHUNK_TOKENS=600
RETRIEVAL_TOP_K=8
RETRIEVAL_MAX_DISTANCE=0.75

OPENAI_TIMEOUT=60
